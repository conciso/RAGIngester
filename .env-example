# ---- LightRAG connection ----
LIGHTRAG_URL=http://lightrag:9621
LIGHTRAG_API_KEY=your-api-key-here

# ---- RAGIngester run configuration ----
# Set automatically by env-tester; set manually for standalone runs.
RAGINGESTER_RUN_GROUP=param_run_001
# Ingestion preset label forwarded by env-tester (e.g. "baseline-ingestion").
# Set automatically by env-tester; override here only for manual runs.
#RAGINGESTER_RUN_LABEL=

# ---- Optional overrides (defaults shown) ----
#RAGINGESTER_CLEAN_DOCS_PATH=/data/clean
#RAGINGESTER_POISONED_DOCS_PATH=/data/poisoned
# Must be the actual host path — Docker daemon mounts these into the RAGChecker container:
RAGINGESTER_TESTCASES_PATH=/home/spark-642e/opt/RAGChecker/testcases
RAGINGESTER_REPORTS_PATH=/home/spark-642e/opt/RAGChecker/reports
#RAGINGESTER_RAGCHECKER_IMAGE=ragchecker:latest
# ragchecker.env inside the container is mapped from RAGChecker/.env on the host (see docker-compose.yml)
#RAGINGESTER_RAGCHECKER_ENV_FILE=/config/ragchecker.env
#RAGINGESTER_POLLING_TIMEOUT_MINUTES=10
#RAGINGESTER_DRY_RUN=false
# Comma-separated stages to run; empty = all stages (e.g. P25PCT,P50PCT)
#RAGINGESTER_STAGES=
# Query-preset label appended to every RAGCHECKER_RUN_LABEL for result attribution.
# Must match a preset label from presets-query.yml (e.g. baseline).
RAGINGESTER_RAGCHECKER_RUN_LABEL=baseline
