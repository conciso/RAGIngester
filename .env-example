# ---- LightRAG connection ----
LIGHTRAG_URL=http://lightrag:9622
LIGHTRAG_API_KEY=your-api-key-here

# ---- RAGIngester run configuration ----
RAGINGESTER_RUN_GROUP=param_run_001

# ---- Optional overrides (defaults shown) ----
#RAGINGESTER_CLEAN_DOCS_PATH=/data/clean
#RAGINGESTER_POISONED_DOCS_PATH=/data/poisoned
# Must be the actual host path — Docker daemon mounts these into the RAGChecker container:
RAGINGESTER_TESTCASES_PATH=/opt/ragchecker/testcases
RAGINGESTER_REPORTS_PATH=/opt/ragchecker/reports
#RAGINGESTER_OVERRIDE_ENV_PATH=/config/override.env
#RAGINGESTER_RAGCHECKER_IMAGE=ragchecker:latest
#RAGINGESTER_RAGCHECKER_ENV_FILE=/config/ragchecker.env
#RAGINGESTER_POLLING_TIMEOUT_MINUTES=10
#RAGINGESTER_DRY_RUN=false
# Comma-separated stages to run; empty = all stages (e.g. P25PCT,P50PCT)
#RAGINGESTER_STAGES=
